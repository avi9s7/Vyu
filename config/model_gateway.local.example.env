# VYU model gateway local configuration example.
# Copy to a local, untracked file before use. Do not commit real secrets.
#
# Local development may use deterministic providers and a local JSON secret file.
# Staging and production require real provider IDs, policy/prompt versions, and
# VYU_PROVIDERS_CONFIG_SECRET_ARN instead of a local secret file.

VYU_ENV=local

# Generation and embedding providers (use deterministic for local smoke only).
VYU_GENERATION_PROVIDER=deterministic
VYU_GENERATION_MODEL=vyu-deterministic-v1
VYU_EMBEDDING_PROVIDER=deterministic
VYU_EMBEDDING_MODEL=vyu-deterministic-v1
VYU_EMBEDDING_DIMENSIONS=1536

# Timeouts and budgets.
VYU_GENERATION_TIMEOUT_SECONDS=120
VYU_EMBEDDING_TIMEOUT_SECONDS=60
VYU_MODEL_MAX_INPUT_TOKENS=120000
VYU_MODEL_MAX_OUTPUT_TOKENS=8192
VYU_MODEL_MAX_COST_MINOR=500
VYU_MODEL_COST_CURRENCY=USD

# Approved policy and prompt versions (required in staging/production).
VYU_MODEL_POLICY_VERSION=model_policy_v1
VYU_PROMPT_TEMPLATE_ID=grounded_answer_v1
VYU_PROMPT_VERSION=grounded_answer_v1.0

# Local secret file for development. Use Secrets Manager ARN in AWS.
# VYU_PROVIDERS_CONFIG_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:vyu/staging/providers
VYU_PROVIDERS_SECRET_FILE=config/dev-providers.json

# Never enable fixture adapters outside local development.
VYU_MODEL_ENABLE_FIXTURE_ADAPTER=false
VYU_MODEL_SECRET_CACHE_TTL_SECONDS=300

# Optional AWS region override for Secrets Manager resolution.
# VYU_AWS_REGION=us-east-1
