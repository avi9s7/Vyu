aws_region  = "ap-south-1"
environment = "prod"

callback_urls = [
  "https://app.example.com/auth/callback",
]

logout_urls = [
  "https://app.example.com/logout",
]

cognito_domain_prefix      = "vyu-prod-login-example"
resource_server_identifier = "https://api.example.com"

tags = {
  Environment = "production"
  Owner       = "platform"
}
