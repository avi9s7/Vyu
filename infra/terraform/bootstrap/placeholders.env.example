# Copy to placeholders.env (gitignored locally) and substitute before terraform apply.
# Used by scripts/bootstrap_aws_placeholders.ps1

AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-south-1

TF_STATE_BUCKET=vyu-terraform-state-example
TF_STATE_LOCK_TABLE=vyu-terraform-state-lock
TF_STATE_KMS_KEY_ARN=arn:aws:kms:ap-south-1:123456789012:key/00000000-0000-0000-0000-000000000000

DEV_APP_HOST=dev.app.vyu.example
STAGING_APP_HOST=staging.app.vyu.example
PROD_APP_HOST=app.vyu.example
ROUTE53_ZONE_ID=Z000000000000000000000

GITHUB_REPO=avi9s7/Vyu
