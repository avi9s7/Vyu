# Example AWS Cognito/OIDC operator config overlay for Vyu production deployments.
# Generate the IdP-specific values with:
# python scripts/render_cognito_operator_env.py --terraform-output-json deploy/aws/cognito/cognito-outputs.json

VYU_AUTH_MODE=oidc_jwks
VYU_TOKEN_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_REPLACE
VYU_TOKEN_AUDIENCE=REPLACE_WITH_COGNITO_APP_CLIENT_ID
VYU_OIDC_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_REPLACE/.well-known/jwks.json
VYU_OIDC_DISCOVERY_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_REPLACE/.well-known/openid-configuration
VYU_OIDC_ALLOWED_ALGORITHMS=RS256
VYU_OIDC_REQUIRED_TOKEN_USE=id
VYU_OIDC_JWKS_CACHE_TTL_SECONDS=300
VYU_OIDC_FETCH_TIMEOUT_SECONDS=2.0

VYU_SQLITE_DB=/app/data/production.sqlite
VYU_PHASE_OUTPUT_DIR=/app/outputs
VYU_TENANT_GOVERNANCE_REGISTRY=/app/config/tenant-governance.json
VYU_REQUIRE_TENANT_GOVERNANCE=true
VYU_REQUIRE_EMAIL_VERIFIED=true

# Smoke-test scope only. Real request scope comes from Cognito JWT claims plus tenant governance grants.
VYU_TENANT_ID=tenant-a
VYU_WORKSPACE_ID=workspace-a
VYU_USER_ID=cognito-smoke-user
VYU_ROLE=reviewer

VYU_INITIALIZE_STORAGE=true
VYU_UNAUTHENTICATED_PATHS=/v1/health
VYU_IDENTITY_ACCESS_AUDIT_ENABLED=true
VYU_API_KEY_AUTH_ENABLED=false
VYU_REQUEST_ID_PREFIX=aws-cognito
VYU_SERVERLESS_DEFAULT_REQUEST_ID=aws-cognito-serverless
