# Vyu local deployment operator configuration example.
# Copy this file to a local, untracked file before use and replace placeholders.
# Do not commit real secrets.

VYU_SQLITE_DB=outputs/production.sqlite
VYU_PHASE_OUTPUT_DIR=outputs
VYU_TOKEN_ISSUER=https://issuer.example
VYU_TOKEN_AUDIENCE=vyu-api
VYU_HS256_SECRET=__REPLACE_WITH_LOCAL_SECRET__

VYU_TENANT_ID=local_tenant
VYU_WORKSPACE_ID=local_workspace
VYU_USER_ID=reviewer-1
VYU_ROLE=vyu:reviewer

VYU_TOKEN_LEEWAY_SECONDS=60
VYU_TOKEN_LIFETIME_SECONDS=300
VYU_UNAUTHENTICATED_PATHS=/v1/health
VYU_INITIALIZE_STORAGE=true
VYU_REQUIRE_EMAIL_VERIFIED=false
VYU_REQUEST_ID_PREFIX=local-smoke
VYU_SERVERLESS_DEFAULT_REQUEST_ID=local-serverless
VYU_SERVERLESS_EXTRA_RESPONSE_HEADERS=x-vyu-deployment-target=local

# Production-operated identity, access, and tenant governance controls.
# The example registry contains reviewer-1 and a local service account only.
VYU_TENANT_GOVERNANCE_REGISTRY=config/tenant_governance.local.example.json
VYU_REQUIRE_TENANT_GOVERNANCE=true
VYU_API_KEY_AUTH_ENABLED=true
VYU_API_KEY_ISSUER=vyu-api-key
VYU_IDENTITY_ACCESS_AUDIT_ENABLED=true

# Enterprise IdP mode for AWS-hosted production deployments.
# Keep VYU_AUTH_MODE=hs256 for local smoke tests. Use oidc_jwks with Amazon
# Cognito, or with Okta/Azure AD/Entra federated through Cognito/OIDC.
# VYU_AUTH_MODE=oidc_jwks
# VYU_TOKEN_ISSUER=https://cognito-idp.<aws-region>.amazonaws.com/<user-pool-id>
# VYU_TOKEN_AUDIENCE=<app-client-id-or-api-audience>
# VYU_OIDC_JWKS_URI=https://cognito-idp.<aws-region>.amazonaws.com/<user-pool-id>/.well-known/jwks.json
# VYU_OIDC_DISCOVERY_URI=https://cognito-idp.<aws-region>.amazonaws.com/<user-pool-id>/.well-known/openid-configuration
# VYU_OIDC_ALLOWED_ALGORITHMS=RS256
# VYU_OIDC_REQUIRED_TOKEN_USE=id
# VYU_OIDC_JWKS_CACHE_TTL_SECONDS=300
# VYU_OIDC_FETCH_TIMEOUT_SECONDS=2.0
